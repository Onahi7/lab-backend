# ============================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# For environment-specific configs, use:
#   .env.development
#   .env.staging
#   .env.production

# ============================================
# APPLICATION SETTINGS
# ============================================

# Port number for the application server
# Default: 3000
PORT=3000

# Node environment: development, staging, production, test
# Default: development
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB connection URI
# Local: mongodb://localhost:27017/lis
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/lis?retryWrites=true&w=majority
# REQUIRED
MONGODB_URI=mongodb://localhost:27017/lis

# ============================================
# JWT AUTHENTICATION
# ============================================

# Secret key for signing JWT tokens
# IMPORTANT: Use a strong, random string (minimum 32 characters)
# Generate using: openssl rand -base64 64
# REQUIRED
JWT_SECRET=your-secret-key-change-in-production

# Access token expiration time
# Examples: 1h, 30m, 15m
# Default: 1h
JWT_ACCESS_TOKEN_EXPIRY=1h

# Refresh token expiration time
# Examples: 7d, 30d, 90d
# Default: 7d
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origin(s) for CORS
# Single origin: http://localhost:5173
# Multiple origins: http://localhost:5173,https://app.example.com
# Default: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: error, warn, info, debug, verbose
# Development: debug or verbose
# Production: warn or error
# Default: info
LOG_LEVEL=debug

# ============================================
# RATE LIMITING
# ============================================

# Time window in seconds for rate limiting
# Default: 60 (1 minute)
RATE_LIMIT_TTL=60

# Maximum number of requests per time window
# Default: 100
RATE_LIMIT_MAX=100

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file size in bytes
# 5MB = 5242880 bytes
# 10MB = 10485760 bytes
# Default: 5242880 (5MB)
MAX_FILE_SIZE=5242880

# Comma-separated list of allowed MIME types
# Default: image/jpeg,image/png,image/gif,application/pdf
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

# SMTP server hostname
# Examples: smtp.gmail.com, smtp.sendgrid.net, smtp.mailtrap.io
EMAIL_HOST=

# SMTP server port
# Common ports: 587 (TLS), 465 (SSL), 25 (unencrypted)
# Default: 587
EMAIL_PORT=587

# Use secure connection (SSL/TLS)
# Values: true, false
# Default: false
EMAIL_SECURE=false

# SMTP authentication username
EMAIL_USER=

# SMTP authentication password
EMAIL_PASSWORD=

# Default "from" email address
# Default: noreply@lis.com
EMAIL_FROM=noreply@lis.com

# ============================================
# SMS CONFIGURATION (Optional)
# ============================================

# SMS provider: twilio, nexmo, aws-sns
# Default: twilio
SMS_PROVIDER=twilio

# Twilio Account SID (if using Twilio)
SMS_ACCOUNT_SID=

# Twilio Auth Token (if using Twilio)
SMS_AUTH_TOKEN=

# SMS sender phone number (E.164 format: +1234567890)
SMS_FROM_NUMBER=

# ============================================
# ADDITIONAL CONFIGURATION (Optional)
# ============================================

# Laboratory Information (for reports)
LAB_NAME=Clinical Laboratory
LAB_LOGO_URL=
LAB_ADDRESS=123 Medical Center Drive, City, Country
LAB_PHONE=+1-234-567-8900
LAB_EMAIL=lab@example.com
LAB_WEBSITE=
LAB_LICENSE_NUMBER=
LAB_ACCREDITATION=

# Error tracking service (e.g., Sentry)
# SENTRY_DSN=

# Application Performance Monitoring
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME=

# Redis configuration (for caching/sessions)
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# NOTES
# ============================================
# 1. Never commit .env files with real credentials to version control
# 2. Add .env* to .gitignore (except .env.example)
# 3. Use strong, unique secrets for JWT tokens
# 4. Use environment variables or secrets management in production
# 5. Rotate secrets regularly
# 6. Keep this template updated when adding new configuration options

