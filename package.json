{
  "name": "hobour-diagnostics-backend",
  "version": "1.0.0",
  "description": "Hobour Diagnostics Laboratory Information System - Backend API",
  "author": "Hobour Diagnostics",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "heroku-postbuild": "npm run build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:admin": "ts-node -r tsconfig-paths/register src/database/seed-admin.ts",
    "seed:serology": "ts-node -r tsconfig-paths/register src/database/seed-serology.ts",
    "migrate:glucose": "ts-node -r tsconfig-paths/register src/database/migrate-glucose-to-mmol.ts",
    "update:prices": "ts-node -r tsconfig-paths/register src/database/update-test-prices.ts",
    "update:rft-ranges": "ts-node -r tsconfig-paths/register src/database/update-rft-ranges.ts",
    "check:serology": "ts-node -r tsconfig-paths/register src/database/check-serology-report.ts",
    "update:glucose-ranges": "ts-node -r tsconfig-paths/register src/database/update-glucose-ranges.ts",
    "seed:catalog": "ts-node -r tsconfig-paths/register src/database/seed-test-catalog.ts",
    "seed:panels": "ts-node -r tsconfig-paths/register src/database/seed-test-panels.ts",
    "seed:electrolytes": "ts-node -r tsconfig-paths/register src/database/seed-electrolytes.ts",
    "seed:machines": "ts-node -r tsconfig-paths/register src/database/seed-machines.ts",
    "fix:catalog": "ts-node -r tsconfig-paths/register src/database/fix-catalog-and-panels.ts",
    "update:rft": "ts-node -r tsconfig-paths/register src/database/update-rft-panel.ts",
    "adjust:catalog": "ts-node -r tsconfig-paths/register src/database/adjust-catalog-from-panels.ts",
    "seed:all": "npm run seed:catalog && npm run seed:panels && npm run adjust:catalog",
    "reset:data": "ts-node -r tsconfig-paths/register src/database/reset-transactional-data.ts",
    "list:tests": "ts-node -r tsconfig-paths/register src/database/list-all-tests.ts",
    "check:ranges": "ts-node -r tsconfig-paths/register src/database/check-test-ranges.ts",
    "check:order-tests": "ts-node -r tsconfig-paths/register src/database/check-order-tests.ts",
    "check:electrolytes": "ts-node -r tsconfig-paths/register src/database/check-electrolyte-panels.ts",
    "check:patient-ages": "ts-node -r tsconfig-paths/register src/database/check-patient-ages.ts",
    "fix:crp-hscrp-link": "ts-node -r tsconfig-paths/register src/database/fix-crp-hscrp-link.ts",
    "fix:electrolyte": "ts-node -r tsconfig-paths/register src/database/fix-electrolyte-duplicate.ts",
    "remove:u-protein": "ts-node -r tsconfig-paths/register src/database/remove-u-protein.ts",
    "update:test-results": "ts-node -r tsconfig-paths/register src/database/update-test-results.ts",
    "fix:urine-protein": "ts-node -r tsconfig-paths/register src/database/fix-urine-protein-category.ts",
    "fix:madinatu-urine": "ts-node -r tsconfig-paths/register src/database/fix-madinatu-urine-protein.ts",
    "check:tests": "node check-test-parameters.js",
    "check:tests:json": "node check-test-parameters-json.js",
    "sample:fbc:api": "node fbc-api-sample.js",
    "sample:fbc:pdf": "node fbc-report-to-pdf.js"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.13",
    "@types/compression": "^1.8.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "helmet": "^8.1.0",
    "mongodb": "^7.1.0",
    "multer": "^2.0.2",
    "mongoose": "^9.1.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
